# ── API de Inteligência Artificial ───────────────────
# Gere em: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-api03-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ── Segurança da Sessão ───────────────────────────────
# Gere com: python -c "import secrets; print(secrets.token_hex(32))"
APP_SECRET_KEY=gere_uma_chave_aleatoria_de_64_chars_hex_aqui

# ── Duração da sessão (horas) ─────────────────────────
SESSION_HOURS=8

# ── Origens permitidas (separadas por vírgula) ────────
# Em produção: coloque seu domínio real
# Ex: https://credito.vendemmia.com.br
ALLOWED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# ── Ativar HTTPS forçado (true em produção) ───────────
HTTPS_ONLY=false
